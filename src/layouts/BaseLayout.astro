---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Carmin Tattoo Studio', description = 'Estudio de tatuaje profesional en Paraná, Entre Ríos' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Google Fonts: Cormorant Garamond + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,700&family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet"
    />

    <!-- Inline blocking script: apply dark class before first paint to prevent FOUC -->
    <script is:inline>
      (function() {
        var theme = null;
        try {
          theme = localStorage.getItem('theme');
        } catch(e) {}
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <ClientRouter />

    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Ir al contenido principal</a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
