---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const galleryItems = await getCollection('gallery');
const artists = await getCollection('artists');
const siteSettings = (await getCollection('siteSettings'))[0];

const featuredItems = galleryItems
  .filter((g) => g.data.featured && g.data.published !== false)
  .slice(0, 6);

function getArtistName(slug: string): string {
  const artist = artists.find((a) => a.id === slug);
  return artist?.data.name ?? slug;
}
---

<BaseLayout
  title="Carmin Tattoo Studio — Tatuajes en Paraná"
  description="Estudio de tatuaje profesional en Paraná, Entre Ríos. Especialistas en blackwork, tradicional, realismo y más."
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <Hero siteSettings={siteSettings} />

  <!-- Featured gallery preview -->
  {featuredItems.length > 0 && (
    <section class="bg-ink-black px-4 pb-32 pt-8">
      <div class="mx-auto max-w-7xl">
        <div class="mb-12 text-center">
          <h2 class="font-display text-3xl font-bold italic text-paper sm:text-4xl">
            Trabajos destacados
          </h2>
          <p class="mt-3 font-body text-sm font-light text-paper/40">
            Una selección de nuestras últimas piezas
          </p>
        </div>

        <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
          {
            featuredItems.map((item) => {
              const artistName = getArtistName(item.data.artist);
              return (
                <div class="group relative mb-4 break-inside-avoid overflow-hidden cursor-pointer">
                  <img
                    src={item.data.image}
                    alt={item.data.title}
                    class="w-full transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-black/80 via-black/10 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <p class="font-display text-lg font-bold italic text-paper">
                      {item.data.title}
                    </p>
                    <p class="mt-1 font-body text-xs font-semibold uppercase tracking-widest text-copper">
                      {artistName}
                    </p>
                  </div>
                </div>
              );
            })
          }
        </div>

        <div class="mt-12 text-center">
          <a
            href="/galeria"
            class="inline-block rounded-sm border border-copper bg-copper px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-paper no-underline transition-all hover:bg-copper-light"
          >
            Ver todas
          </a>
        </div>
      </div>
    </section>
  )}

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
