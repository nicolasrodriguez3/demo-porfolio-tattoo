---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  artist: CollectionEntry<'artists'>;
  portfolioCount: number;
}

const { artist, portfolioCount } = Astro.props;
const { name, slug, photo, styles } = artist.data;
---

<a
  href={`/artistas/${slug}`}
  class="group block rounded-sm border border-stone-200 bg-white p-6 transition-all hover:border-copper/30 hover:shadow-lg hover:shadow-copper/5 no-underline dark:border-warm-gray dark:bg-charcoal"
>
  <!-- Photo -->
  <div class="aspect-square overflow-hidden rounded-full bg-stone-100 dark:bg-warm-gray">
    <img
      src={photo}
      alt={name}
      class="h-full w-full object-cover transition-all duration-500 group-hover:scale-105 group-hover:opacity-90"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- Name -->
  <h2 class="mt-4 font-display text-2xl font-bold italic text-ink transition-colors group-hover:text-copper dark:text-paper">
    {name}
  </h2>

  <!-- Style tags -->
  <div class="mt-2 flex flex-wrap gap-2">
    {styles.map((style) => (
      <span class="rounded-full border border-copper/30 px-3 py-0.5 font-body text-xs font-light text-copper">
        {style}
      </span>
    ))}
  </div>

  <!-- Portfolio count -->
  {portfolioCount === 0 ? (
    <p class="mt-3 font-body text-xs font-light text-ink/40 italic dark:text-paper/40">
      Sin trabajos publicados
    </p>
  ) : (
    <p class="mt-3 font-body text-xs font-light text-ink/30 dark:text-paper/30">
      {portfolioCount} trabajo{portfolioCount !== 1 ? 's' : ''}
    </p>
  )}
</a>
