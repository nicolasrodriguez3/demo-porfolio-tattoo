---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Página no encontrada — Carmin Tattoo Studio">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="flex min-h-[60vh] items-center justify-center bg-ink-black px-4">
    <div class="text-center">
      <h1 class="font-display text-8xl font-bold italic text-copper">404</h1>
      <p class="mt-4 font-body text-lg font-light text-paper/60">
        La página que buscás no existe
      </p>
      <a
        href="/"
        class="mt-8 inline-block rounded-sm border border-copper bg-copper px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-paper transition-colors hover:bg-copper-light no-underline"
      >
        Volver al inicio
      </a>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
