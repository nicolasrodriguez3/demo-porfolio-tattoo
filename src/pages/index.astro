---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const galleryItems = await getCollection('gallery');
const featuredItems = galleryItems.filter((g) => g.data.featured).slice(0, 6);
---

<BaseLayout
  title="Carmin Tattoo Studio — Tatuajes en Paraná"
  description="Estudio de tatuaje profesional en Paraná, Entre Ríos. Especialistas en blackwork, tradicional, realismo y más."
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <!-- Hero -->
  <section class="relative flex min-h-[80vh] items-center justify-center bg-ink-black px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="font-display text-5xl font-bold italic leading-tight text-paper sm:text-6xl lg:text-7xl">
        CARMIN
        <br />
        <span class="text-copper">TATTOO</span>
      </h1>
      <p class="mx-auto mt-6 max-w-xl font-body text-base font-light leading-relaxed text-paper/60 sm:text-lg">
        Estudio de tatuaje profesional en Paraná. Arte sobre la piel con pasión y precisión.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/galeria"
          class="inline-block rounded-sm border border-copper bg-copper px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-paper transition-colors hover:bg-copper-light no-underline"
        >
          Ver galería
        </a>
        <a
          href="/contacto"
          class="inline-block rounded-sm border border-paper/20 px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-paper/80 transition-colors hover:border-paper/40 hover:text-paper no-underline"
        >
          Contacto
        </a>
      </div>
    </div>
  </section>

  <!-- Featured gallery preview -->
  {featuredItems.length > 0 && (
    <section class="bg-ink-black px-4 pb-24 pt-16">
      <div class="mx-auto max-w-6xl">
        <h2 class="mb-2 font-display text-3xl font-bold italic text-paper">Trabajos destacados</h2>
        <p class="mb-10 font-body text-sm font-light text-paper/40">
          Una selección de nuestros mejores trabajos
        </p>

        <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
          {
            featuredItems.map((item) => (
              <div class="mb-4 break-inside-avoid">
                <img
                  src={item.data.image}
                  alt={item.data.title}
                  class="w-full rounded-sm"
                  loading="lazy"
                  decoding="async"
                />
                <div class="mt-2">
                  <h3 class="font-body text-sm font-semibold text-paper">{item.data.title}</h3>
                  <p class="font-body text-xs text-paper/40">{item.data.artist}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  )}

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
