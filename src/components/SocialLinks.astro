---
export interface Props {
  instagram?: string;
  facebook?: string;
  variant?: 'inline' | 'stacked';
}

const { instagram, facebook, variant = 'inline' } = Astro.props;
const ulClass = variant === 'stacked' ? 'flex flex-col gap-2' : 'flex items-center gap-4';
---

<ul class={ulClass}>
  {instagram && (
    <li>
      <a
        href={`https://instagram.com/${instagram.replace('@', '')}`}
        target="_blank"
        rel="noopener noreferrer"
        class="font-body text-sm font-light uppercase tracking-widest text-ink transition-colors hover:text-copper no-underline dark:text-paper"
      >
        Instagram
      </a>
    </li>
  )}
  {facebook && facebook.trim() && (
    <li>
      <a
        href={`https://facebook.com/${facebook}`}
        target="_blank"
        rel="noopener noreferrer"
        class="font-body text-sm font-light uppercase tracking-widest text-ink transition-colors hover:text-copper no-underline dark:text-paper"
      >
        Facebook
      </a>
    </li>
  )}
</ul>
