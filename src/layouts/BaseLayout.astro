---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const {
  title = 'Tattoo Studio',
  description = 'Estudio de tatuaje profesional en Paraná, Entre Ríos. Especialistas en blackwork, tradicional, realismo, dotwork y más.',
  image = '/images/og-default.jpg',
  url = 'https://tattoo-studio.vercel.app',
  type = 'website',
} = Astro.props;

const siteUrl = 'https://tattoo-studio.vercel.app';
const fullUrl = url.startsWith('http') ? url : `${siteUrl}${url}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullImage} />
    <meta property="og:url" content={fullUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Tattoo Studio" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullImage} />

    <!-- Google Fonts: Cormorant Garamond + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,700;1,700&family=Inter:wght@300;400;600&display=swap"
      rel="stylesheet"
    />

    <!-- Inline blocking script: apply dark class before first paint to prevent FOUC -->
    <script is:inline>
      (function() {
        var theme = null;
        try {
          theme = localStorage.getItem('theme');
        } catch(e) {}
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
          document.documentElement.style.backgroundColor = '#0A0A0A';
        } else {
          document.documentElement.style.backgroundColor = '#F5F0EB';
        }
      })();
    </script>

    <!-- Guard for view transitions: inject theme into the incoming document before swap.
         Astro's swapRootAttributes() copies attributes from the new document to the live
         document, so modifying event.newDocument is the only way the dark class survives. -->
    <script>
      document.addEventListener('astro:before-swap', function(event) {
        var theme = null;
        try {
          theme = localStorage.getItem('theme');
        } catch(e) {}
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          event.newDocument.documentElement.classList.add('dark');
          event.newDocument.documentElement.style.backgroundColor = '#0A0A0A';
        } else {
          event.newDocument.documentElement.style.backgroundColor = '#F5F0EB';
        }
      });
    </script>

    <ClientRouter />

    <title>{title}</title>

    <!-- JSON-LD Schema.org LocalBusiness -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Tattoo Studio",
        "image": "https://tattoo-studio.vercel.app/images/og-default.jpg",
        "url": "https://tattoo-studio.vercel.app",
        "telephone": "+54 343 123-4567",
        "email": "info@tattoostudio.com",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "San Martín 123",
          "addressLocality": "Paraná",
          "addressRegion": "Entre Ríos",
          "addressCountry": "AR"
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
            "opens": "15:00",
            "closes": "20:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": "Saturday",
            "opens": "10:00",
            "closes": "14:00"
          }
        ],
        "sameAs": [
          "https://instagram.com/tattoostudio"
        ]
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Ir al contenido principal</a>

    <slot name="header" />

    <main id="main-content">
      <slot />
    </main>

    <slot name="footer" />
  </body>
</html>
