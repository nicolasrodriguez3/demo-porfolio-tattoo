---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Página no encontrada — Tattoo Studio">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="flex min-h-[70vh] items-center justify-center bg-paper px-4 transition-colors dark:bg-ink-black">
    <div class="text-center">
      <h1 class="font-display text-9xl font-bold italic leading-none text-copper/50 sm:text-[10rem]">
        404
      </h1>

      <div class="mx-auto mt-6 h-px w-16 bg-copper/30" />

      <p class="mt-6 font-body text-xl font-light text-ink/60 dark:text-paper/60">
        Página no encontrada
      </p>

      <p class="mx-auto mt-3 max-w-md font-body text-sm font-light text-ink/40 dark:text-paper/40">
        La página que buscás no existe o fue movida. Revisá la URL o volvé al inicio.
      </p>

      <div class="mt-10 flex items-center justify-center gap-4">
        <a
          href="/"
          class="inline-block rounded-sm border border-copper bg-copper px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-paper transition-all hover:bg-copper-light no-underline"
        >
          Volver al inicio
        </a>
        <a
          href="/contacto"
          class="inline-block rounded-sm border border-stone-300 bg-transparent px-8 py-3 font-body text-sm font-semibold uppercase tracking-widest text-ink transition-all hover:border-copper hover:text-copper no-underline dark:border-warm-gray dark:text-paper"
        >
          Contacto
        </a>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
