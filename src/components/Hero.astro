---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  siteSettings: CollectionEntry<'siteSettings'>;
}

const { siteSettings } = Astro.props;
const { studioName, homeHeroTitle, homeHeroDescription } = siteSettings.data;
---

<section class="relative flex min-h-[90vh] items-center justify-center overflow-hidden bg-linear-to-b from-paper to-stone-100 dark:bg-none dark:bg-ink-black">
  <!-- Fondo degradado con efecto de luz (dark mode) -->
  <div class="absolute inset-0 hidden dark:block bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,var(--color-charcoal)_0%,transparent_70%)]" />

  <!-- Patrón texturizado sutil -->
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.03]"
    style="background-image: radial-gradient(circle, #B87333 1px, transparent 1px); background-size: 40px 40px;"
  />

  <div class="relative z-10 mx-auto max-w-4xl px-4 text-center">
    <p class="mb-6 font-body text-xs font-semibold uppercase tracking-[0.3em] text-copper/80">
      {homeHeroTitle}
    </p>

    <h1 class="font-display text-6xl font-bold italic leading-[1.1] tracking-tight text-ink transition-colors dark:text-paper sm:text-7xl lg:text-8xl">
      {studioName}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl font-body text-base font-light leading-relaxed text-ink/70 transition-colors dark:text-paper/70 sm:text-lg">
      {homeHeroDescription}
    </p>

    <div class="mt-12">
      <a
        href="/galeria"
        class="group relative inline-flex items-center gap-2 rounded-sm border border-copper bg-copper px-10 py-4 font-body text-sm font-semibold uppercase tracking-widest text-paper no-underline transition-all hover:bg-copper-light hover:shadow-lg hover:shadow-copper/20"
      >
        Ver galería
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
        >
          <path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Gradiente inferior de transición -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-paper to-transparent dark:from-ink-black" />
</section>
