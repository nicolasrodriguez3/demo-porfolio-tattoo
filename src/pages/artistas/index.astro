---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArtistCard from '../../components/ArtistCard.astro';
import { getCollection } from 'astro:content';

const artists = await getCollection('artists');
const galleryItems = await getCollection('gallery');

// Build a map of artist slug → portfolio image count
const portfolioCounts = new Map<string, number>();
for (const artist of artists) {
  const count = galleryItems.filter(
    (g) => g.data.artist === (artist.data.slug ?? artist.id) && g.data.published !== false,
  ).length;
  portfolioCounts.set((artist.data.slug ?? artist.id), count);
}
---

<BaseLayout
  title="Artistas — Tattoo Studio"
  description="Conocé a nuestros artistas tatuadores en Paraná, Entre Ríos"
>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="bg-paper px-4 pb-24 pt-8 transition-colors dark:bg-ink-black">
    <div class="mx-auto max-w-6xl">
      <h1 class="font-display text-4xl font-bold italic text-ink transition-colors dark:text-paper">Nuestros Artistas</h1>
      <p class="mt-2 font-body text-sm font-light text-ink/40 dark:text-paper/40">
        Conocé a nuestro equipo de tatuadores
      </p>

      {artists.length === 0 ? (
        <div class="mt-16 text-center">
          <p class="font-body text-base text-ink/40 dark:text-paper/40">Conociendo a nuestros artistas...</p>
        </div>
      ) : (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {artists.map((artist) => (
            <ArtistCard
              artist={artist}
              portfolioCount={portfolioCounts.get((artist.data.slug ?? artist.id)) ?? 0}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
